<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="algeo.gui.RegressionController">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>
    <top>
        <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Regresi Polinomial Berganda" BorderPane.alignment="CENTER" />
    </top>
    <center>
        <VBox spacing="10.0" BorderPane.alignment="CENTER">
            <children>
                <Label text="Info Data &amp; Persamaan:" />
                <TextArea fx:id="infoArea" editable="false" prefHeight="150.0" prefWidth="200.0" promptText="Silakan muat file data (.txt)." />
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Label text="Taksir y untuk:" />
                        <TextField fx:id="estimateField" prefWidth="300.0" promptText="Masukkan x1, x2, ... dipisah spasi" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
    <bottom>
        <VBox spacing="10.0" BorderPane.alignment="CENTER">
            <children>
                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Button onAction="#handleLoadFile" text="Load File" />
                        <Button onAction="#handleEstimate" text="Taksir Nilai" />
                        <Button onAction="#handleBack" text="Kembali" />
                    </children>
                </HBox>
                <Label text="Output Taksiran:" />
                <TextArea fx:id="outputArea" editable="false" prefHeight="150.0" prefWidth="200.0" promptText="Hasil taksiran akan ditampilkan di sini." style="-fx-font-family: 'monospaced';" />
            </children>
        </VBox>
    </bottom>
</BorderPane>